TEMPORAL_ADDRESS=localhost:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=dsg-orchestrator

API_HOST=0.0.0.0
API_PORT=8090

# Legacy backend is optional during local development.
# When empty or DRY_RUN=true, activities return simulated success.
LEGACY_BACKEND_BASE_URL=https://digitalstoregames.pythonanywhere.com
LEGACY_API_KEY=
LEGACY_EMAIL_PATH=/remarket_v2
LEGACY_WHATSAPP_PATH=/remarket_whatsapp
LEGACY_WHATSAPP_AI_PATH=/remarket_whatsapp_ai
LEGACY_PURCHASE_CHECK_PATH=/user_has_purchase
LEGACY_EVENT_CALLBACK_PATH=
# Shared secret used by the workflow event callback only. Sent as
# X-Callback-Secret. Independent from LEGACY_API_KEY so the WhatsApp flow
# auth is not affected.
LEGACY_EVENT_CALLBACK_SECRET=
LEGACY_WHATSAPP_PROCESS_PATH=/temporal/whatsapp/process

DRY_RUN=true
ASSUME_PURCHASED_ON_CHECK_ERROR=true
HTTP_TIMEOUT_SECONDS=20
ACTIVITY_MAX_WORKERS=20

# Local dev launcher only. Uses Temporal CLI dev server through the Python SDK.
TEMPORAL_DEV_PORT=7233
TEMPORAL_DEV_UI=true
TEMPORAL_DEV_UI_PORT=8233
TEMPORAL_DEV_DB=.temporal/dev-server.sqlite

